{
  "title": "k3s Cluster Overview",
  "uid": "k3s-cluster-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Nodes Ready",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 3 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"})",
          "legendFormat": "Ready Nodes"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pods Running",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "unit": "none"
        }
      },
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "Running Pods"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU Auslastung Cluster",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ]
    },
    {
      "id": 4,
      "title": "RAM Auslastung Cluster",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes))",
          "legendFormat": "RAM %"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU pro Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "100 - (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "RAM pro Node",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "{{ instance }} used"
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "{{ instance }} total"
        }
      ]
    },
    {
      "id": 7,
      "title": "Netzwerk Eingehend pro Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|cni.*|flannel.*|veth.*\"}[5m])",
          "legendFormat": "{{ instance }} {{ device }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Netzwerk Ausgehend pro Node",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2 }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|cni.*|flannel.*|veth.*\"}[5m])",
          "legendFormat": "{{ instance }} {{ device }}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Pods pro Namespace",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "count by (namespace) (kube_pod_status_phase{phase=\"Running\"})",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Alle Pods",
      "type": "table",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "options": {
        "sortBy": [{ "displayName": "Namespace", "desc": false }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "filterable": true } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 1 }
                  ]
                }
              },
              { "id": "mappings", "value": [
                { "type": "value", "options": { "1": { "text": "Running", "color": "green" } } },
                { "type": "value", "options": { "0": { "text": "Not Running", "color": "red" } } }
              ]}
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "kube_pod_info",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "kube_pod_status_phase{phase=\"Running\"} == 1",
          "legendFormat": "",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "node": "Node",
              "Value #A": "Info",
              "Value #B": "Status"
            },
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "container": true,
              "created_by_kind": true,
              "created_by_name": true,
              "host_ip": true,
              "host_network": true,
              "instance": true,
              "job": true,
              "phase": true,
              "pod_ip": true,
              "uid": true,
              "Info": true
            }
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Disk Auslastung pro Node",
      "type": "bargauge",
      "gridPos": { "x": 8, "y": 20, "w": 16, "h": 8 },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          },
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "{{ instance }}"
        }
      ]
    }
  ]
}
