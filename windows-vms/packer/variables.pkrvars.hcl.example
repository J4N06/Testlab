# Kopieren nach variables.pkrvars.hcl und anpassen (nie ins Git!)
# Verwendung: packer build -var-file="variables.pkrvars.hcl" windows-2025.pkr.hcl

proxmox_url          = "https://192.168.2.12:8006/api2/json"
proxmox_token_id     = "root@pam!packer"
proxmox_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node         = "pve"
storage              = "local-lvm"

# Vorher einmalig prepare.sh ausführen — erstellt dieses ISO aus dem Original
windows_iso = "windows-server-2025-autounattend.iso"

# Administrator-Passwort für das Template
# Muss mit dem Wert in autounattend.xml übereinstimmen (Packer2025!)
vm_password = "Packer2025!"
