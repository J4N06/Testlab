# Kopieren nach terraform.tfvars und anpassen (nie ins Git!)
proxmox_url       = "https://192.168.2.12:8006"
proxmox_api_token = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_node      = "TESTLAB-PROX01"
